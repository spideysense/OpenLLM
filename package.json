{
  "name": "aspen",
  "version": "0.4.6",
  "description": "Run the best open source AI locally. No API keys. No subscriptions. No terminal.",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:all": "npm run build:renderer && electron-builder --mac --win",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release:mac": "node scripts/release-mac.js",
    "smoke": "npm run build:renderer && node scripts/smoke-test.js"
  },
  "build": {
    "appId": "com.runonaspen.app",
    "productName": "Aspen",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "build/**/*",
      "registry/**/*",
      "!vendor/**/*",
      "!vendor"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "artifactName": "Aspen-mac.${ext}",
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "notarize": {
        "teamId": "S6UBG93XBS"
      },
      "identity": "Mayank Mehta (S6UBG93XBS)"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Aspen-win.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "spideysense",
        "repo": "OpenLLM"
      }
    ],
    "afterAllArtifactBuild": "scripts/staple-dmg.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@vitejs/plugin-react": "^4.2.1",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "jsdom": "^23.2.0",
    "jsonwebtoken": "^9.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "uuid": "^13.0.0",
    "vite": "^5.0.12",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "author": {
    "name": "Aspen",
    "email": "hello@runonaspen.com"
  },
  "optionalDependencies": {
    "robotjs": "0.6.0"
  }
}