{
  "name": "aspen",
  "version": "0.7.9",
  "description": "Run the best open source AI locally. No API keys. No subscriptions. No terminal.",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:all": "npm run build:renderer && electron-builder --mac --win",
    "build:linux": "npm run build:renderer && electron-builder --linux AppImage --$(node -p \"process.arch==='arm64'?'arm64':'x64'\")",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release:mac": "node scripts/release-mac.js",
    "smoke": "node scripts/smoke-behavioral.js"
  },
  "build": {
    "appId": "com.runonaspen.app",
    "productName": "Aspen",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "build/**/*",
      "registry/**/*",
      "!vendor/**/*",
      "!vendor"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "artifactName": "Aspen-mac.${ext}",
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Aspen uses the microphone for voice chat with your local AI. Audio is processed on your device and never leaves it.",
        "NSCameraUsageDescription": "Aspen does not use the camera.",
        "NSAudioCaptureUsageDescription": "Aspen captures screen content locally for Computer Use. Nothing leaves your device."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "notarize": true,
      "identity": "Mayank Mehta (S6UBG93XBS)"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Aspen-win.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility",
      "artifactName": "Aspen-linux-${arch}.${ext}",
      "target": [
        {
          "target": "deb",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "arm64"
          ]
        }
      ],
      "executableArgs": [
        "--no-sandbox"
      ],
      "desktop": {
        "entry": {
          "Name": "Aspen",
          "Comment": "Private AI that runs on your hardware",
          "Categories": "Utility;Development;",
          "StartupWMClass": "Aspen"
        }
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "spideysense",
        "repo": "OpenLLM"
      }
    ],
    "afterAllArtifactBuild": "scripts/staple-dmg.js",
    "npmRebuild": true,
    "deb": {}
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@vitejs/plugin-react": "^4.2.1",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^8.2.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^23.2.0",
    "jsonwebtoken": "^9.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "uuid": "^13.0.0",
    "vite": "^5.0.12",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0",
    "@electron/rebuild": "^4.0.4"
  },
  "author": {
    "name": "Aspen",
    "email": "hello@runonaspen.com"
  },
  "homepage": "https://github.com/spideysense/OpenLLM"
}
