# ── Aspen gateway (free inference on the box) ────────────────────────────────
ASPEN_BASE_URL=https://YOUR-TUNNEL.runonaspen.com/v1
ASPEN_API_KEY=YOUR-ASPEN-KEY
ASPEN_MODEL=local

# ── Goal ─────────────────────────────────────────────────────────────────────
GOAL_DOWNLOADS_PER_DAY=10

# ── Identity (so collectors don't get rate-limited / blocked) ────────────────
USER_AGENT=aspen-growth-agent/0.1 (+https://runonaspen.com)
GITHUB_REPO=spideysense/OpenLLM
APPSTORE_ID=6775307566

# ── Optional integrations (agent runs without these; they make it sharper) ───
# Slack incoming webhook for the daily digest + approval queue
SLACK_WEBHOOK_URL=
# GitHub token (raises API limits, enables traffic/clones data)
GITHUB_TOKEN=
# Google Search Console: service-account JSON path + verified site URL
GSC_CREDENTIALS_JSON=
GSC_SITE_URL=https://runonaspen.com/

# Hard safety switch: agent never publishes to third-party platforms itself
ALLOW_AUTOPUBLISH=false
